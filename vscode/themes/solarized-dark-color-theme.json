    "input.border": "#022e3a",
    "input.placeholderForeground": "#93A1A1AA",
    "badge.background": "#047aa6",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#047aa6",
    "textLink.foreground": "#d30102",
