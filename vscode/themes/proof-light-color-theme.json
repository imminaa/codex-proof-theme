{
  "$schema": "vscode://schemas/color-theme",
  "name": "Codex — Proof Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#2f312d",
    "focusBorder": "#3d755d",
    "descriptionForeground": "#8b877c",
    "errorForeground": "#b84a45",
    "titleBar.activeBackground": "#d7d5cf",
    "titleBar.activeForeground": "#000000",
    "titleBar.inactiveBackground": "#e3e1db",
    "activityBar.background": "#efede6",
    "activityBar.foreground": "#000000",
    "activityBar.activeBorder": "#3d755d",
    "activityBarBadge.background": "#3d755d",
    "activityBarBadge.foreground": "#ffffff",
    "sideBar.background": "#efede6",
    "sideBar.foreground": "#4b4d48",
    "sideBarTitle.foreground": "#2f312d",
    "sideBarSectionHeader.background": "#e3e1db",
    "list.activeSelectionBackground": "#d8dfd6",
    "list.activeSelectionForeground": "#2f312d",
    "list.inactiveSelectionBackground": "#e3e1db",
    "list.hoverBackground": "#e3e1db",
    "editorGroupHeader.tabsBackground": "#efede6",
    "tab.activeBackground": "#f5f3ed",
    "tab.activeForeground": "#2f312d",
    "tab.activeBorderTop": "#3d755d",
    "tab.inactiveBackground": "#efede6",
    "tab.inactiveForeground": "#8b877c",
    "editor.background": "#f5f3ed",
    "editor.foreground": "#2f312d",
    "editorCursor.foreground": "#3d755d",
    "editorLineNumber.foreground": "#8b877c",
    "editorLineNumber.activeForeground": "#3d755d",
    "editor.selectionBackground": "#d8dfd6",
    "editor.inactiveSelectionBackground": "#e3e1db",
    "editor.lineHighlightBackground": "#efede680",
    "editor.findMatchBackground": "#d3b45b70",
    "editorWhitespace.foreground": "#e3e1db",
    "editorIndentGuide.background1": "#e3e1db",
    "editorIndentGuide.activeBackground1": "#8b877c",
    "editorError.foreground": "#b84a45",
    "editorWarning.foreground": "#d3b45b",
    "editorInfo.foreground": "#5f6ac2",
    "editorHint.foreground": "#3d755d",
    "diffEditor.insertedTextBackground": "#3d755d24",
    "diffEditor.removedTextBackground": "#b84a4524",
    "panel.background": "#efede6",
    "panel.border": "#d7d5cf",
    "statusBar.background": "#d7d5cf",
    "statusBar.foreground": "#000000",
    "button.background": "#3d755d",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#548670",
    "input.background": "#f5f3ed",
    "input.foreground": "#2f312d",
    "input.border": "#e3e1db",
    "input.placeholderForeground": "#8b877c",
    "badge.background": "#3d755d",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#3d755d",
    "textLink.foreground": "#3d755d",
    "editorWidget.background": "#efede6",
    "editorWidget.foreground": "#2f312d",
    "editorWidget.border": "#d7d5cf",
    "menu.background": "#efede6",
    "menu.foreground": "#2f312d",
    "menu.selectionBackground": "#d8dfd6",
    "quickInput.background": "#efede6",
    "quickInput.foreground": "#2f312d",
    "quickInputList.focusBackground": "#d8dfd6",
    "terminal.background": "#f5f3ed",
    "terminal.foreground": "#2f312d",
    "terminalCursor.foreground": "#3d755d",
    "gitDecoration.addedResourceForeground": "#3d755d",
    "gitDecoration.deletedResourceForeground": "#b84a45",
    "gitDecoration.modifiedResourceForeground": "#5f6ac2"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8b877c"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#3d755d"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#d3b45b"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5f6ac2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#5f6ac2"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#3d755d"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation",
        "punctuation.bracket",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#7a766d"
      }
    },
    {
      "scope": [
        "variable",
        "meta.object-literal.key",
        "meta.object.member",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#2f312d"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#8b877c",
    "string": "#3d755d",
    "number": "#d3b45b",
    "regexp": "#d3b45b",
    "keyword": "#5f6ac2",
    "modifier": "#5f6ac2",
    "type": "#5f6ac2",
    "class": "#5f6ac2",
    "enum": "#5f6ac2",
    "interface": "#5f6ac2",
    "struct": "#5f6ac2",
    "typeParameter": "#5f6ac2",
    "function": "#3d755d",
    "method": "#3d755d",
    "variable": "#3d755d",
    "parameter": "#3d755d",
    "property": "#3d755d",
    "enumMember": "#d3b45b",
    "operator": "#8b877c",
    "namespace": "#5f6ac2",
    "macro": "#5f6ac2",
    "decorator": "#5f6ac2"
  }
}
