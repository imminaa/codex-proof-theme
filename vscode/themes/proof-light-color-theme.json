  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8b877c"
      }
    },
    {
      "name": "Strings and symbols",
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#3d755d"
      }
    },
    {
      "name": "Numbers, booleans, and regular expressions",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#d3b45b"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5f6ac2"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#5f6ac2"
      }
    },
    {
      "name": "Functions and calls",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#3d755d"
      }
    },
    {
      "name": "Operators and punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation",
        "punctuation.bracket",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#7a766d"
      }
    },
    {
      "name": "Variables and properties",
      "scope": [
        "variable",
        "meta.object-literal.key",
        "meta.object.member",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#2f312d"
      }
    },
    {
      "name": "Invalid and deprecated",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#b84a45"
      }
    },
    {
      "name": "Markup headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#5f6ac2"
      }
    },
    {
      "name": "Markup links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#3d755d"
      }
    },
    {
      "name": "Markup inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#3d755d"
      }
    },
    {
      "name": "Markup deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#b84a45"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#8b877c",
    "string": "#3d755d",
    "number": "#d3b45b",
    "regexp": "#d3b45b",
    "keyword": "#5f6ac2",
    "modifier": "#5f6ac2",
    "type": "#5f6ac2",
    "class": "#5f6ac2",
    "enum": "#5f6ac2",
    "interface": "#5f6ac2",
    "struct": "#5f6ac2",
    "typeParameter": "#5f6ac2",
    "function": "#3d755d",
    "method": "#3d755d",
    "variable": "#2f312d",
    "parameter": "#2f312d",
    "property": "#2f312d",
    "enumMember": "#d3b45b",
    "operator": "#7a766d",
    "namespace": "#5f6ac2",
    "macro": "#5f6ac2",
    "decorator": "#5f6ac2"
  }
}
