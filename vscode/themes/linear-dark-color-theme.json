{
  "$schema": "vscode://schemas/color-theme",
  "name": "Codex — Linear Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#e6e9ef",
    "focusBorder": "#5e6ad2",
    "descriptionForeground": "#636b7b",
    "errorForeground": "#ff7e78",
    "titleBar.activeBackground": "#2b2c31",
    "titleBar.activeForeground": "#ffffff",
    "titleBar.inactiveBackground": "#1c1d20",
    "activityBar.background": "#080a0f",
    "activityBar.foreground": "#ffffff",
    "activityBar.activeBorder": "#5e6ad2",
    "activityBarBadge.background": "#5e6ad2",
    "activityBarBadge.foreground": "#ffffff",
    "sideBar.background": "#080a0f",
    "sideBar.foreground": "#d8dce6",
    "sideBarTitle.foreground": "#f7f8f8",
    "sideBarSectionHeader.background": "#1c1d20",
    "list.activeSelectionBackground": "#2d3152",
    "list.activeSelectionForeground": "#e3e4e6",
    "list.inactiveSelectionBackground": "#1c1d20",
    "list.hoverBackground": "#1c1d20",
    "editorGroupHeader.tabsBackground": "#0f1219",
    "tab.activeBackground": "#17181d",
    "tab.activeForeground": "#e3e4e6",
    "tab.activeBorderTop": "#606acc",
    "tab.inactiveBackground": "#0f0f11",
    "tab.inactiveForeground": "#636b7b",
    "editor.background": "#17181d",
    "editor.foreground": "#e6e9ef",
    "editorCursor.foreground": "#8c97ff",
    "editorLineNumber.foreground": "#636b7b",
    "editorLineNumber.activeForeground": "#606acc",
    "editor.selectionBackground": "#2d3152",
    "editor.inactiveSelectionBackground": "#1c1d20",
    "editor.lineHighlightBackground": "#0f0f1180",
    "editor.findMatchBackground": "#f5c56a70",
    "editorWhitespace.foreground": "#1c1d20",
    "editorIndentGuide.background1": "#1c1d20",
    "editorIndentGuide.activeBackground1": "#636b7b",
    "editorError.foreground": "#ff7e78",
    "editorWarning.foreground": "#f5c56a",
    "editorInfo.foreground": "#8c97ff",
    "editorHint.foreground": "#606acc",
    "diffEditor.insertedTextBackground": "#69c96724",
    "diffEditor.removedTextBackground": "#ff7e7824",
    "panel.background": "#0a0c11",
    "panel.border": "#2b2c31",
    "statusBar.background": "#2b2c31",
    "statusBar.foreground": "#ffffff",
    "button.background": "#5e6ad2",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#737cd2",
    "input.background": "#17181d",
    "input.foreground": "#e3e4e6",
    "input.border": "#1c1d20",
    "input.placeholderForeground": "#636b7b",
    "badge.background": "#606acc",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#606acc",
    "textLink.foreground": "#5e6ad2",
    "editorWidget.background": "#0f0f11",
    "editorWidget.foreground": "#e3e4e6",
    "editorWidget.border": "#2b2c31",
    "menu.background": "#0f0f11",
    "menu.foreground": "#e3e4e6",
    "menu.selectionBackground": "#2d3152",
    "quickInput.background": "#0f0f11",
    "quickInput.foreground": "#e3e4e6",
    "quickInputList.focusBackground": "#2d3152",
    "terminal.background": "#17181d",
    "terminal.foreground": "#e3e4e6",
    "terminalCursor.foreground": "#606acc",
    "gitDecoration.addedResourceForeground": "#69c967",
    "gitDecoration.deletedResourceForeground": "#ff7e78",
    "gitDecoration.modifiedResourceForeground": "#8c97ff"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#636b7b"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7ad9c0"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.character.escape",
        "regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#f5c56a"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8c97ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#73b7ff"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#c2a1ff"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.definition.tag",
        "punctuation",
        "punctuation.bracket",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#b5bccb"
      }
    },
    {
      "scope": [
        "variable",
        "meta.object-literal.key",
        "meta.object.member",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#e6e9ef"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "#636b7b",
    "string": "#7ad9c0",
    "number": "#f5c56a",
    "regexp": "#f5c56a",
    "keyword": "#8c97ff",
    "modifier": "#8c97ff",
    "type": "#73b7ff",
    "class": "#73b7ff",
    "enum": "#73b7ff",
    "interface": "#73b7ff",
    "struct": "#73b7ff",
    "typeParameter": "#73b7ff",
    "function": "#c2a1ff",
    "method": "#c2a1ff",
    "variable": "#c2a1ff",
    "parameter": "#c2a1ff",
    "property": "#c2a1ff",
    "enumMember": "#f5c56a",
    "operator": "#636b7b",
    "namespace": "#73b7ff",
    "macro": "#8c97ff",
    "decorator": "#8c97ff"
  }
}
