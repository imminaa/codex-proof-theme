{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/proof-palette.schema.json",
  "title": "Proof theme palette",
  "type": "object",
  "required": ["name", "type", "source", "colors"],
  "properties": {
    "name": { "type": "string" },
    "type": { "const": "light" },
    "source": { "type": "object" },
    "colors": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
      }
    }
  }
}
